{
  "name": "colliejs",
  "private": true,
  "version": "0.0.0",
  "description": "type-safe css-in-js library with zero runtime",
  "author": "colliedog1001@gmail.com",
  "license": "MIT",
  "keywords": [
    "css-in-js",
    "react",
    "zero runtime",
    "typescript",
    "css",
    "styled-components"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "jest --changedSince=main",
    "test:ci": "jest --ci ",
    "preversion": "pnpm -r build",
    "prepare": "husky install",
    "watchtype": "tsc --project . --watch",
    "typecheck": "tsc --project . --noEmit",
    "release": "./scripts/cli.mjs release"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "dependencies": {
    "@babel/helper-builder-react-jsx": "^7.19.0",
    "@babel/parser": "^7.20.15",
    "@babel/traverse": "^7.20.13",
    "@babel/types": "^7.21.5",
    "@c3/dbg": "^1.1.1",
    "@c3/types": "^1.1.0",
    "@c3/utils": "^1.3.4",
    "@nindaff/ascii-tree": "^0.0.2",
    "@rollup/plugin-babel": "^6.0.3",
    "@rollup/plugin-commonjs": "^24.0.1",
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-typescript": "^11.0.0",
    "@rollup/pluginutils": "^5.0.2",
    "@scriptbot/cli": "^1.0.155",
    "@types/resolve": "^1.20.2",
    "@unstyled-ui/css": "^1.1.73",
    "babel-plugin-transform-import-meta": "^2.2.0",
    "core": "link:@types/@babel/core",
    "csstype": "^3.1.1",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "npmlog": "^7.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resolve": "^1.22.1",
    "rollup": "^3.13.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.7",
    "@babel/generator": "^7.19.6",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@commitlint/cli": "^17.4.4",
    "@commitlint/config-conventional": "^17.4.4",
    "@pnpm/filter-workspace-packages": "^7.0.7",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-replace": "^5.0.2",
    "@rollup/plugin-strip": "^3.0.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/babel__generator": "^7.6.4",
    "@types/babel__traverse": "^7.18.3",
    "@types/jest": "^29.2.4",
    "@types/lodash": "^4.14.191",
    "@types/node": "^18.11.18",
    "@types/npmlog": "^4.1.4",
    "@types/react": "^18.0.24",
    "@types/react-dom": "^18.0.8",
    "@typescript-eslint/eslint-plugin": "^5.45.1",
    "@typescript-eslint/parser": "^5.45.1",
    "@vitejs/plugin-react": "^2.2.0",
    "babel-jest": "^29.3.1",
    "eslint": "^8.29.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "^6.6.1",
    "eslint-plugin-react": "^7.31.11",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.3",
    "jest": "^29.3.1",
    "jest-environment-jsdom": "^29.3.1",
    "jest-localstorage-mock": "^2.4.25",
    "lerna": "^6.4.1",
    "lint-staged": "^13.1.2",
    "organize-imports-cli": "^0.10.0",
    "polished": "^4.2.2",
    "prettier": "^2.8.0",
    "react-test-renderer": "^18.2.0",
    "semver": "^7.3.8",
    "typescript": "^4.6.4",
    "vite": "^3.2.3",
    "vite-plugin-inspect": "^0.7.15",
    "zx": "^7.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -c 'tsc  --project . --noEmit'",
      "eslint --cache --fix"
    ],
    "*.{js,jsx}": [
      "organize-imports-cli"
    ],
    "*.{css,md}": "prettier --write"
  }
}
